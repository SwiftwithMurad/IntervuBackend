NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority
JWT_ACCESS_SECRET=replace_with_at_least_32_chars_access_secret
JWT_REFRESH_SECRET=replace_with_at_least_32_chars_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
BREVO_API_KEY=
EMAIL_FROM=example@mail.com
EMAIL_SENDER_NAME=Intervu
# Public URL of this API (no trailing slash). Used for email <img> logo; Vercel sets VERCEL_URL if unset.
PUBLIC_BASE_URL=https://intervu-backend.vercel.app
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

ADMIN_IDS=YourPrimaryAccountID

ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=